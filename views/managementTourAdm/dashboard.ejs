<div class="bg-gradient-to-br from-blue-50 to-blue-100 
            p-6 rounded-xl shadow-md border border-blue-200">

  <!-- GRID UTAMA -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">

    <!-- TOTAL JAMAAH -->
    <div id="daftar-jamaah" class=" bg-white rounded-lg p-4 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold">
        Total Jamaah
      </p>
      <p class="text-3xl font-bold text-blue-600 mt-1">
        <%= stats.totalJamaah %>
      </p>
      <p class="text-xs text-gray-500 mt-1">
        Ikut Tour Ziyaroh ADM Pamijahan - Pangandaran 2026
      </p>
    </div>

    <!-- DIKENAKAN ONGKOS -->
    <div class="bg-green-50 rounded-lg p-4 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold">
        Dikenakan Ongkos
      </p>
      <p class="text-2xl font-bold text-green-600 mt-1">
        <%= stats.meta.kenaOngkos %> Org
      </p>
      <p class="text-xs text-gray-500 mt-1">
        Sudah bayar: <%= stats.meta.berbayar %> Org
      </p>
    </div>

    <!-- PRIORITAS -->
    <div class="bg-yellow-50 rounded-lg p-4 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold">
        Prioritas
      </p>
      <p class="text-2xl font-bold text-yellow-600 mt-1">
        <%= stats.meta.prioritas %> Org
      </p>
      <p class="text-xs text-gray-500 mt-1">
        Ongkos dibebaskan
      </p>
    </div>

    <!-- PIUTANG -->
    <div class="bg-red-50 rounded-lg p-4 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold">
        Total Piutang
      </p>
      <p class="text-2xl font-bold text-red-600 mt-1">
        Rp <%= stats.totalPiutang.toLocaleString('id-ID') %>
      </p>
      <p class="text-xs text-gray-500 mt-1">
        Ongkos belum lunas
      </p>
    </div>

  </div>

  <!-- SECTION KEUANGAN -->
  <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4">

    <!-- TOTAL TAGIHAN -->
    <div class="bg-white rounded-lg p-4 shadow-sm border">
      <p class="text-xs text-gray-500 font-semibold uppercase">Total Tagihan</p>
      <p class="text-xl font-bold text-gray-700 mt-1">
        Rp <%= stats.totalTagihan.toLocaleString('id-ID') %>
      </p>
      <p class="text-xs text-gray-500 mt-1">
        <%= stats.meta.kenaOngkos %> Org x Rp <%= Ongkos.toLocaleString('id-ID') %>
      </p>
    </div>

    <!-- TOTAL DIBAYAR -->
    <div class="bg-white rounded-lg p-4 shadow-sm border">
      <p class="text-xs text-gray-500 font-semibold uppercase">Total Dibayar</p>
      <p class="text-xl font-bold text-green-600 mt-1">
        Rp <%= stats.totalOngkos.toLocaleString('id-ID') %>
      </p>
      <p class="text-xs text-gray-500 mt-1">
        Ongkos yang sudah masuk
      </p>
    </div>

    <!-- STATUS KEUANGAN -->
    <div class="bg-white rounded-lg p-4 shadow-sm border">
      <p class="text-xs text-gray-500 font-semibold uppercase">Status Pelunasan</p>
      <p class="text-xl font-bold mt-1 
          <%= stats.persentaseLunas >= 80 ? 'text-green-600' : 
              stats.persentaseLunas >= 50 ? 'text-yellow-600' : 
              'text-red-600' %>">
        <%= stats.persentaseLunas %>%
      </p>
    </div>

  </div>

  <!-- PROGRESS BAR -->
  <div class="mt-4">
    <div class="w-full bg-gray-200 rounded-full h-3">
      <div class="h-3 rounded-full transition-all duration-500
          <%= stats.persentaseLunas >= 80 ? 'bg-green-500' : stats.persentaseLunas >= 50 ? 'bg-yellow-500' :'bg-red-500' %>" <%-`style="width: ${stats.persentaseLunas}%"` %>>
      </div>
    </div>
  </div>

</div>

<!-- anggaran -->
 <div class="max-w-6xl mx-auto p-6 space-y-6 mb-56 mt-6">

  <!-- HEADER -->
  <div class="flex justify-between items-center">
    <h2 class="text-2xl font-bold tracking-tight">
      Ringkasan Keuangan Ziyaroh
    </h2>
    <span class="text-sm text-gray-500">
      <%= waktu %>
    </span>
  </div>

  <!-- GRID UTAMA -->
  <div class="grid grid-cols-2 gap-6">

    <!-- Dana Dibutuhkan -->
    <div class="bg-white shadow-lg rounded-2xl p-6 border">
      <p class="text-sm text-gray-500">Dana Dibutuhkan</p>
      <h3 class="text-2xl font-bold mt-2">
        Rp <%= stats.totalEstimasi.toLocaleString('id-ID') %>
      </h3>
    </div>

    <!-- Dana Tersedia -->
    <div class="bg-white shadow-lg rounded-2xl p-6 border">
      <p class="text-sm text-gray-500">Dana Terkumpul</p>
      <h3 class="text-2xl font-bold mt-2 text-blue-600">
        Rp <%= stats.totalOngkos.toLocaleString('id-ID') %>
      </h3>
    </div>

    <!-- Status Surplus / Defisit -->
    <div class="col-span-2 bg-white shadow-lg rounded-2xl p-6 border">
      <p class="text-sm text-gray-500">Status Anggaran</p>

      <% let selisih = stats.totalOngkos - stats.totalEstimasi; %>

      <h3 class="text-2xl font-bold mt-2 
        <%= selisih >= 0 ? 'text-green-600' : 'text-red-600' %>">
        <%= selisih >= 0 ? 'Surplus' : 'Defisit' %>
      </h3>

      <p class="text-sm mt-2">
        Rp <%= Math.abs(selisih).toLocaleString('id-ID') %>
      </p>
      <p class="text-xs font-bold mt-2 
        <%= selisih >= 0 ? 'text-green-600' : 'text-red-600' %>">
        <%= selisih >= 0 ? 'Lebih Dari Anggaran' : 'Kurang Dari Anggaran' %>
      </p>
    </div>

  </div>

  <!-- REALISASI -->
  <div class="grid grid-cols-2 gap-6">

    <!-- Total Pengeluaran -->
    <div class="bg-white shadow-lg rounded-2xl p-6 border">
      <p class="text-sm text-gray-500">Total Pengeluaran</p>
      <h3 class="text-2xl font-bold mt-2 text-red-500">
        Rp <%= stats.totalPengeluaran.toLocaleString('id-ID') %>
      </h3>
    </div>

    <!-- Sisa Dana -->
    <div class="bg-white shadow-lg rounded-2xl p-6 border">
      <p class="text-sm text-gray-500">Sisa Dana</p>

      <% let sisaDana = stats.totalOngkos - stats.totalPengeluaran; %>

      <h3 class="text-2xl font-bold mt-2 
        <%= sisaDana >= 0 ? 'text-green-600' : 'text-red-600' %>">
        Rp <%= sisaDana.toLocaleString('id-ID') %>
      </h3>

      <p class="text-xs mt-1 text-gray-500">
        <%= sisaDana >= 0 ? 'Dana Aman' : 'Kas Minus' %>
      </p>
    </div>

  </div>

  <!-- PROGRESS BAR REALISASI -->
  <% let persenRealisasi = (stats.totalPengeluaran / stats.totalEstimasi) * 100; %>

  <div class="bg-white shadow-lg rounded-2xl p-6 border">
    <div class="flex justify-between mb-2">
      <span class="text-sm text-gray-600">Realisasi Anggaran</span>
      <span class="text-sm font-semibold">
        <%= persenRealisasi.toFixed(1) %>%
      </span>
    </div>

    <div class="w-full bg-gray-200 rounded-full h-4">
      <div class="h-4 rounded-full 
        <%= persenRealisasi > 100 ? 'bg-red-600' : 'bg-green-500' %>"
        <%- `style="width:${persenRealisasi}%"` %>>
      </div>
    </div>
  </div>

</div>

<!-- menu navigasi -->
<div class="fixed bottom-8 right-8 flex gap-3 flex-col">
  <a href="#daftar-jamaah" class="bg-blue-500 hover:bg-blue-600 text-white font-semibold py-3 px-4 rounded-full shadow-lg transition-all hover:shadow-xl flex items-center gap-2">
    👥 Jamaah
  </a>
  <a href="#daftar-anggaran"
    class="bg-purple-500 hover:bg-purple-600 text-white font-semibold py-3 px-4 rounded-full shadow-lg transition-all hover:shadow-xl flex items-center gap-2">
    📊 Anggaran
  </a>
  <a href="#daftar-pengeluaran" class="bg-red-500 hover:bg-red-600 text-white font-semibold py-3 px-4 rounded-full shadow-lg transition-all hover:shadow-xl flex items-center gap-2">
    💸 Pengeluaran
  </a>
</div>

<script>
  document.querySelectorAll('.fixed a').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href'));
      if (target) target.scrollIntoView({
        behavior: 'smooth'
      });
    });
  });
</script>